{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42",
  "scripts": {
    "build": "nuxt build",
    "vault:login": "hcp auth login && hcp profile init",
    "dev": "nuxt dev",
    "dev:hcp": "hcp vs run -- nuxt dev",
    "studio": "prisma studio",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "prisma generate && nuxt prepare",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test --project=smoke",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "audit": "yarn npm audit --all --recursive",
    "sbom": "npx --yes @anchore/syft . -o cyclonedx-json=sbom.cdx.json",
    "secrets:scan": "gitleaks detect --source . --verbose"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/rules": "^4.15.1",
    "@vee-validate/yup": "^4.15.1",
    "better-auth": "^1.6.14",
    "dotenv": "^17.4.2",
    "nuxt": "^4.4.7",
    "pg": "^8.21.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "resend": "^6.12.4",
    "vue": "latest",
    "vue-router": "^5.1.0",
    "vuetify-nuxt-module": "^0.19.5",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "@vue/compiler-dom": "^3.5.35",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
