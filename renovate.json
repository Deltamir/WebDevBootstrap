{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separatePatchReleases"
  ],
  "schedule": ["before 4am on Wednesday"],
  "labels": ["dependencies", "renovate"],
  "packageRules": [
    {
      "groupName": "Nuxt ecosystem",
      "matchPackagePrefixes": ["nuxt", "@nuxt/"]
    },
    {
      "groupName": "Vue ecosystem",
      "matchPackagePrefixes": [
        "vue",
        "@vue/",
        "vue-router",
        "pinia",
        "@pinia/",
        "vuetify"
      ]
    },
    {
      "groupName": "Prisma",
      "matchPackagePrefixes": ["prisma", "@prisma/"]
    },
    {
      "groupName": "Vitest",
      "matchPackagePrefixes": ["vitest", "@vitest/"]
    },
    {
      "groupName": "Playwright",
      "matchPackagePrefixes": ["playwright", "@playwright/"]
    },
    {
      "groupName": "ESLint ecosystem",
      "matchPackagePrefixes": [
        "eslint",
        "@eslint/",
        "typescript-eslint",
        "eslint-plugin-"
      ]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on the first day of the month"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  }
}
